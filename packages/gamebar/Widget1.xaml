<Page
    x:Class="gamebar.Widget1"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:gamebar"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

  <Grid x:Name="RootGrid"
        PointerWheelChanged="OnPointerWheelChanged"
        Tapped="InteractionLayer_Tapped">

    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup x:Name="ViewStates">
        <VisualState x:Name="Unpinned">
          <Storyboard>
            <DoubleAnimation Storyboard.TargetName="FullView"
                             Storyboard.TargetProperty="Opacity"
                             To="1"
                             Duration="0:0:0.2"/>

            <DoubleAnimation Storyboard.TargetName="MiniView"
                             Storyboard.TargetProperty="Opacity"
                             To="0"
                             Duration="0:0:0.15"/>
          </Storyboard>

          <VisualState.Setters>
            <Setter Target="FullView.Visibility" Value="Visible"/>
            <Setter Target="MiniView.Visibility" Value="Collapsed"/>
          </VisualState.Setters>
        </VisualState>

        <VisualState x:Name="Pinned">
          <Storyboard>
            <DoubleAnimation Storyboard.TargetName="MiniView"
                             Storyboard.TargetProperty="Opacity"
                             To="1"
                             Duration="0:0:0.2"/>

            <DoubleAnimation Storyboard.TargetName="FullView"
                             Storyboard.TargetProperty="Opacity"
                             To="0"
                             Duration="0:0:0.15"/>
          </Storyboard>

          <VisualState.Setters>
            <Setter Target="FullView.Visibility" Value="Collapsed"/>
            <Setter Target="MiniView.Visibility" Value="Visible"/>
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>
    
    <Border CornerRadius="16"
            Background="{ThemeResource SystemControlAcrylicWindowBrush}"
            Padding="12">
      
      <Grid>
        
        <StackPanel x:Name="FullView"
                    Opacity="1"
                    Spacing="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
          
          <Border Width="160" Height="160" CornerRadius="12">
            <Image x:Name="AlbumArt" Stretch="UniformToFill" />
          </Border>

          <StackPanel Spacing="2">
            <TextBlock x:Name="SongTitle"
                       Text="Song Title"
                       FontSize="16"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Foreground="White" />

            <TextBlock x:Name="Artist"
                       Text="Artist"
                       FontSize="13"
                       Opacity="0.7"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Foreground="White" />
          </StackPanel>

          <ProgressBar x:Name="ProgressBar"
                       Height="4"
                       Minimum="0"
                       Maximum="100"
                       Margin="0,6,0,0" />

          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Spacing="20">

            <Button x:Name="PrevButton"
                    Content="A"
                    Click="PrevButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    Width="40" Height="40"
                    IsTabStop="True" />

            <Button x:Name="PlayPauseButton"
                    Content="B"
                    Click="PlayPauseButton_Click"
                    Width="48" Height="48"
                    IsTabStop="True" />

            <Button x:Name="NextButton"
                    Content="C"
                    Click="NextButton_Click"
                    Width="40" Height="40"
                    IsTabStop="True" />

          </StackPanel>
        </StackPanel>

        <Grid x:Name="MiniView"
              Opacity="0"
              Visibility="Collapsed"
              Width="220"
              Height="60">

          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Border Width="44" Height="44"
                  CornerRadius="8"
                  VerticalAlignment="Center">
            <Image Source="{Binding ElementName=AlbumArt, Path=Source}"
                   Stretch="UniformToFill"/>
          </Border>

          <StackPanel Grid.Column="1"
                      VerticalAlignment="Center"
                      Spacing="4">

            <TextBlock Text="{Binding ElementName=SongTitle, Path=Text}"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis"
                       Foreground="White"/>

            <ProgressBar x:Name="MiniProgressBar"
                         Height="3"
                         Minimum="0"
                         Maximum="100"/>
          </StackPanel>

        </Grid>

        <Grid x:Name="OfflineOverlay"
              Background="#AA000000"
              Visibility="Collapsed"
              IsHitTestVisible="True">

          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="10">

            <TextBlock Text="App not running"
                       FontSize="16"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <Button Content="Retry"
                    Click="RetryButton_Click"
                    Padding="12,6"/>
          </StackPanel>
        </Grid>

      </Grid>
    </Border>
  </Grid>
</Page>